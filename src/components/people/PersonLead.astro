---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import Avatar from './Avatar.astro';

interface Props {
  person: CollectionEntry<'people'>;
}

const { person } = Astro.props;
const { data } = person;
const { Content } = await render(person);
---

<div class="person-lead" style="margin-top: 24px;">
  <a class="person-lead-avatar" href={`/about/${person.id}`} aria-label={`View ${data.name}'s profile`}>
    <Avatar person={person} />
  </a>
  <div>
    <div class="role">{data.role}</div>
    <h2 style="font-size: 48px; margin-top: 8px;">
      <a class="person-lead-name" href={`/about/${person.id}`}>{data.name}</a>
    </h2>
    <div style="font-size: 18px; color: var(--fg-muted); max-width: 56ch; margin-top: 16px;">
      <Content />
    </div>
    <div style="display: flex; gap: 8px; margin-top: 24px; flex-wrap: wrap;">
      <a class="btn btn-accent" href={`/about/${person.id}`}>View profile →</a>
      {data.links.website && <a class="btn" href={data.links.website}>Website</a>}
      {data.links.cv && <a class="btn" href={data.links.cv}>CV (PDF)</a>}
      {data.links.scholar && <a class="btn" href={data.links.scholar}>Google Scholar</a>}
      {data.links.dblp && <a class="btn" href={data.links.dblp}>DBLP</a>}
      {data.links.researchgate && <a class="btn" href={data.links.researchgate}>ResearchGate</a>}
      {data.email && <a class="btn btn-ghost" href={`mailto:${data.email}`}>{data.email}</a>}
    </div>
  </div>
</div>
