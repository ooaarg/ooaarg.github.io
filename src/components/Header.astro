---
import KineticLogo from './KineticLogo.astro';
import ThemeToggle from './ThemeToggle.astro';
import MobileNav from './MobileNav.tsx';

interface Props {
  active?: 'home' | 'blog' | 'pubs' | 'about';
}

const { active } = Astro.props;
const path = Astro.url.pathname;
const isActive = (route: string) => {
  if (route === '/') return path === '/' || active === 'home';
  return path.startsWith(route);
};
---

<header class="site-header">
  <div class="container nav">
    <span class="brand">
      <KineticLogo size="28px" transitionName="brand-title" />
    </span>
    <div class="nav-spacer"></div>
    <nav class="nav-links" aria-label="Primary">
      <a href="/" class={isActive('/') ? 'active' : ''}>Home</a>
      <a href="/blog" class={isActive('/blog') ? 'active' : ''}>Blog</a>
      <a href="/publications" class={isActive('/publications') ? 'active' : ''}>Publications</a>
      <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
    </nav>
    <div class="nav-spacer"></div>
    <div class="nav-tools">
      <ThemeToggle />
      <a class="btn btn-sm desktop-only" href="/#join">Contact</a>
      <MobileNav client:load active={path === '/' ? '/' : '/' + path.split('/')[1]} />
    </div>
  </div>
</header>
