---
import { getCollection } from 'astro:content';
import Site from '../layouts/Site.astro';
import FeaturedHero from '../components/home/FeaturedHero.tsx';
import AreasOfResearch from '../components/home/AreasOfResearch.astro';
import LatestPubs from '../components/home/LatestPubs.astro';
import JoinStrip from '../components/home/JoinStrip.astro';
import { featuredCarousel, paperUrl } from '../lib/pubs';

import '../styles/home.css';

const pubs = await getCollection('publications');

const slides = featuredCarousel(pubs).map((p) => ({
  id: p.id,
  title: p.data.title,
  venue: p.data.venue,
  tag: p.data.tag,
  summary: p.data.summary,
  paper: paperUrl(p.data),
  arxiv: p.data.arxiv,
  github: p.data.github,
  pdf: p.data.pdf,
}));
---

<Site
  active="home"
  title="OOAARG — Online Optimization And Applications Research Group"
  description="A research group on online optimization, online learning, bandits, and DBMS optimization. Provable regret guarantees, practical deployment."
>
  <FeaturedHero client:load transition:animate="none" slides={slides} />

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <div class="kicker">Areas of research</div>
          <h2>What we work on</h2>
        </div>
      </div>
      <AreasOfResearch pubs={pubs} />
    </div>
  </section>

  <LatestPubs />
  <JoinStrip />
</Site>
